PORT=3001

# Path to the compiled llama_infer binary (relative to web/ or absolute).
# On Windows: ..\build\Release\llama_infer.exe
# On Linux/macOS: ../build/llama_infer
LLAMA_INFER_BIN=../build/Release/llama_infer.exe

# Semicolon-separated (Windows) or colon-separated (Linux/macOS) list of
# directories to scan for .ll2c model files.
LLAMA_MODEL_DIRS=/path/to/your/models;../artifacts

# Default model and tokenizer loaded at startup.
LLAMA_MODEL_PATH=/path/to/your/model.ll2c
LLAMA_TOKENIZER_PATH=/path/to/your/tokenizer.json

# Chat template: tinyllama | tinyllama-chatml | llama2 | llama4
LLAMA_CHAT_TEMPLATE=tinyllama

# Optional system prompt injected at the start of every conversation.
LLAMA_SYSTEM_PROMPT=You are a helpful assistant.

# Generation defaults (all overridable per-request from the UI).
LLAMA_MAX_NEW=256
LLAMA_MAX_CONTEXT=2048
LLAMA_TEMPERATURE=0.7
LLAMA_TOP_K=40
LLAMA_TOP_P=0.9
LLAMA_REPEAT_PENALTY=1.05

# Extra flags forwarded verbatim to llama_infer (e.g. --int8-streaming).
LLAMA_EXTRA_ARGS=
